# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your values
# Run from the vector_ev_docs directory:
#   cp .env.example .env
#   # Edit .env with your API keys and preferences
#   python -m webapp.backend
#   streamlit run webapp/frontend.py

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================

# Choose which LLM provider to use
# Options: "anthropic" (default), "groq"
RAG_LLM_PROVIDER=anthropic

# Model to use (depends on provider)
# Anthropic options:
#   - claude-haiku-4-5-20251001 (fast, cheap) [DEFAULT]
#   - claude-3-5-sonnet-20241022 (better quality)
# Groq options:
#   - mixtral-8x7b-32768 (fast)
#   - llama-3.1-70b-versatile (high quality)
#   - llama-3.2-11b-vision-preview (vision)
RAG_LLM_MODEL=claude-haiku-4-5-20251001

# ============================================================================
# API KEYS (Required - get from provider websites)
# ============================================================================

# Anthropic API Key
# Get it at: https://console.anthropic.com/
# Format: sk-ant-v0-...
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Groq API Key
# Get it at: https://console.groq.com/
# Format: gsk_...
# FREE tier available with generous rate limits
#GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# RAG AGENT CONFIGURATION
# ============================================================================

# Enable query expansion (generates alternative phrasings for better retrieval)
# IMPACT: Each expansion generates ~1 LLM call
# true = slower but may get more relevant results (generates 4 query variations = 4 LLM calls)
# false = 1 LLM call only, faster (RECOMMENDED for cost control)
# NOTE: Agent may call retrieve_context multiple times regardless of this setting
RAG_ENABLE_QUERY_EXPANSION=false

# Logging level
# Options: DEBUG, INFO (default), WARNING, ERROR
RAG_LOG_LEVEL=INFO

# ============================================================================
# PDF INGESTION CONFIGURATION
# ============================================================================

# Batch size for vector DB upsert during PDF ingestion
# Larger PDFs are ingested in batches to avoid memory overflow
# Default: 30 (good for most systems)
# Increase if you have plenty of RAM: 50-100
# Decrease if getting memory errors: 10-20
RAG_INGEST_BATCH_SIZE=30

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

STREAMLIT_SERVER_PORT=8502

# ============================================================================
# VECTOR DB CONFIGURATION
# ============================================================================

VECTOR_DB_PATH=./ev_vector_db
