# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
STREAMLIT_SERVER_PORT=8501

# ============================================================================
# RAG CONFIGURATION
# ============================================================================

# Enable/disable query expansion for better retrieval
# Set to "false" or "0" to disable (faster but less accurate retrieval)
RAG_ENABLE_QUERY_EXPANSION=true

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================

# Choose LLM provider: "anthropic" (default) or "groq"
# Determines which API is used for:
# - Agent inference (main RAG queries)
# - Query expansion (if enabled)
# - Image vision analysis (during PDF ingestion)
RAG_LLM_PROVIDER=anthropic

# Model name for the selected provider
# Anthropic defaults: "claude-haiku-4-5-20251001", "claude-3-5-sonnet-20241022"
# Groq defaults: "mixtral-8x7b-32768", "llama-3.1-70b-versatile", "llama-3.2-11b-vision-preview"
RAG_LLM_MODEL=claude-haiku-4-5-20251001

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO (default), WARNING, ERROR
RAG_LOG_LEVEL=INFO

# ============================================================================
# VECTOR DB CONFIGURATION
# ============================================================================
VECTOR_DB_PATH=./ev_vector_db

# ============================================================================
# API KEYS
# ============================================================================

# Anthropic API key (required if RAG_LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Groq API key (required if RAG_LLM_PROVIDER=groq)
# Get free API key at https://console.groq.com/
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx
